# Supabase - valores publicos usados pelo cliente
NEXT_PUBLIC_SUPABASE_URL=https://seu-projeto.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sua-chave-anon

# Conexao usada exclusivamente no servidor
DATABASE_URL=postgresql://postgres.seu-projeto:SENHA@aws-0-regiao.pooler.supabase.com:5432/postgres

# Google Calendar - service account + delegacao em todo o dominio
GOOGLE_SERVICE_ACCOUNT_CLIENT_EMAIL=calendar-reader@seu-projeto.iam.gserviceaccount.com
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\nSUA_CHAVE\n-----END PRIVATE KEY-----\n"

# Um unico usuario delegado (legado)
GOOGLE_WORKSPACE_SUBJECT=agenda@seudominio.com.br

# Ou varios usuarios delegados, separados por virgula
GOOGLE_WORKSPACE_SUBJECTS=mentor1@seudominio.com.br,mentor2@seudominio.com.br

# Lista de calendarios lidos para cada usuario delegado; use primary para a agenda principal
GOOGLE_CALENDAR_IDS=primary
